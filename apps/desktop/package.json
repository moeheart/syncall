{
  "name": "@syncall/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Syncall desktop client",
  "author": "Syncall Team",
  "type": "module",
  "main": "src/electron/main.cjs",
  "scripts": {
    "build": "vite build",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-desktop-dev.ps1",
    "dev:host": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:client": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-electron-dev.ps1",
    "dev:dual": "concurrently -k \"npm run dev:host\" \"wait-on tcp:5173 && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-electron-dev.ps1 --profile=alice\" \"wait-on tcp:5173 && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-electron-dev.ps1 --profile=bob\"",
    "package:dir": "npm run build && electron-builder --win dir",
    "package:win": "npm run build && electron-builder --win nsis",
    "test": "node --test test/*.test.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "edu.washu.syncall",
    "files": [
      "dist/**/*",
      "src/electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@syncall/shared": "0.1.0",
    "chokidar": "^4.0.3",
    "socket.io-client": "^4.8.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "35.1.4",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "wait-on": "^8.0.3"
  }
}
